{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.5.1",
  "default_locale": "en",
  "description": "__MSG_extDescription__",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "favicon.png",
    "48": "favicon.png",
    "128": "favicon.png"
  },
  "action": {
    "default_title": "__MSG_extName__"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": [
    "contextMenus",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http: https:;"
  }
}
